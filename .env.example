# Required on Vercel
DATABASE_URL="postgres://user:password@host:5432/dbname"
SESSION_SECRET="replace-with-a-long-random-secret-min-32-chars"
BOARD_USERNAME="styret"
BOARD_PASSWORD="replace-with-strong-password"

# E-mail varsling fra Veggen
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
MAIL_FROM_EMAIL="no-reply@your-domain.no"
MAIL_FROM_NAME="Klubbens Nettside"
BOARD_NOTIFICATION_EMAIL="styret@your-domain.no"
